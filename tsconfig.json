{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022"
  },
  "include": [
    "smart_env.config.d.ts",
    "src/**/*.d.ts",
    "src/**/*.js",
    "src/**/*.ts",
    "manifest.json"
  ]
}
