{
  "name": "smart-lookup-obsidian",
  "version": "0.1.6",
  "type": "module",
  "description": "Smart Lookup plugin for Obsidian (query-first semantic retrieval). Ask questions and find notes by meaning.",
  "scripts": {
    "build": "node esbuild.js",
    "release": "node release.js",
    "prepare-release": "node --env-file=.env releases/run_format_release_notes.js",
    "test": "npx ava --verbose"
  },
  "author": "🌴 Brian (Brian Petro)",
  "license": "SEE LICENSE IN LICENSE",
  "dependencies": {
    "obsidian": "latest",
    "obsidian-smart-env": "file:../obsidian-smart-env",
    "smart-collections": "file:../jsbrains/smart-collections",
    "smart-sources": "file:../jsbrains/smart-sources"
  },
  "devDependencies": {
    "ava": "^6.0.1",
    "esbuild": "^0.25.9"
  },
  "ava": {
    "files": [
      "src/**/*.test.js"
    ],
    "require": []
  },
  "workspaces": [
    "../jsbrains/*",
    "../obsidian-smart-env"
  ]
}
